# --- Python / ML ---
__pycache__/
*.py[cod]
*$py.class
.ipynb_checkpoints/

# --- Dataset / Data (Local only) ---
# This ignores the folders but keeps the directory structure if you add a .gitkeep
dataset/images/train/
dataset/images/val/
dataset/labels/train/
dataset/labels/val/
# If you have raw zip files or old datasets
dataset/*.zip
dataset/*.rar

# --- YOLO / Training Artifacts ---
*.pt
*.onnx
*.engine
# Ignores all training run folders
script/runs/
script/runs_v1_baseline/
script/synth_rescue_v2_production/

# --- Blender / 3D Assets ---
*.blend1
*.blend2
*.blend3
*.blend4
*.blend5
quit.blend
# Keep your master blend files, but ignore temporary lock files
*.blend@

# --- Environments / Local Config ---
.venv/
env/
venv/
ENV/
.vscode/
.idea/

# --- OS Specific ---
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini